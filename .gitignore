# ----------------------------------------------------------------------------
# Editor / AI / IDE
# ----------------------------------------------------------------------------
.claude/
.cursor/
.aider*
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------------
node_modules/
**/node_modules/

# ----------------------------------------------------------------------------
# Build output
# ----------------------------------------------------------------------------
client/dist/
client/.angular/
client/tmp/
client/out-tsc/
*.tsbuildinfo

# ----------------------------------------------------------------------------
# Secrets — never commit
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
server/.env
server/.env.*
!server/.env.example

# ----------------------------------------------------------------------------
# Uploads (user-generated content)
# ----------------------------------------------------------------------------
server/uploads/*
!server/uploads/.gitkeep

# ----------------------------------------------------------------------------
# Logs / coverage / OS
# ----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
.nyc_output/

# ----------------------------------------------------------------------------
# MongoDB local data (if anyone ever runs it inside the repo)
# ----------------------------------------------------------------------------
data/db/
*.mongodb-data/
